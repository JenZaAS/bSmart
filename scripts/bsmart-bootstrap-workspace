#!/usr/bin/env python3
"""Bootstrap bSmart into a mounted Hermes workspace.

This helper is designed for VPS/Dokploy setup from the host side. It keeps
bSmart-System as a live Git checkout in the target workspace (not baked into the
image), creates fresh instance-local bSmart content, and prints the Compose/Dokploy
settings that should be present for the agent to load and maintain bSmart.
"""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path

DEFAULT_REPO_URL = "https://github.com/JenZaAS/bSmart.git"
HERMES_HOOK = "At session start, read /workspace/bSmart-System/bSmart.md and follow it.\n"


def run(cmd: list[str], *, cwd: Path | None = None, check: bool = True) -> subprocess.CompletedProcess[str]:
    proc = subprocess.run(cmd, cwd=cwd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    if check and proc.returncode != 0:
        joined = " ".join(cmd)
        raise SystemExit(f"ERROR: command failed ({joined})\n{proc.stderr.strip() or proc.stdout.strip()}")
    return proc


def command_exists(name: str) -> bool:
    return shutil.which(name) is not None


def write_if_missing(path: Path, content: str) -> bool:
    if path.exists():
        return False
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    return True


def install_dir(path: Path, uid: int | None, gid: int | None, mode: int = 0o775) -> None:
    path.mkdir(parents=True, exist_ok=True)
    try:
        path.chmod(mode)
    except PermissionError:
        pass
    if uid is not None or gid is not None:
        try:
            os.chown(path, -1 if uid is None else uid, -1 if gid is None else gid)
        except PermissionError:
            pass


def chown_tree(path: Path, uid: int | None, gid: int | None) -> None:
    if uid is None and gid is None:
        return
    for root, dirs, files in os.walk(path):
        for name in [*dirs, *files]:
            p = Path(root) / name
            try:
                os.chown(p, -1 if uid is None else uid, -1 if gid is None else gid)
            except PermissionError:
                pass
    try:
        os.chown(path, -1 if uid is None else uid, -1 if gid is None else gid)
    except PermissionError:
        pass


def ensure_system_repo(workspace: Path, repo_url: str) -> str:
    target = workspace / "bSmart-System"
    if not command_exists("git"):
        raise SystemExit("ERROR: git is required to clone/update bSmart-System")
    if not (target / ".git").exists():
        run(["git", "clone", repo_url, str(target)])
        action = "cloned"
    else:
        run(["git", "remote", "set-url", "origin", repo_url], cwd=target)
        run(["git", "config", "--unset-all", "core.sshCommand"], cwd=target, check=False)
        run(["git", "pull", "--ff-only"], cwd=target)
        action = "updated"
    return action


def maybe_init_content_git(content_root: Path, mode: str, agent_name: str) -> str:
    if mode == "none":
        return "not initialized"
    if not command_exists("git"):
        return "skipped — git unavailable"
    if not (content_root / ".git").exists():
        run(["git", "init", "-b", "main"], cwd=content_root)
        run(["git", "config", "user.name", agent_name], cwd=content_root)
        run(["git", "config", "user.email", f"{agent_name.lower().replace(' ', '-')}@local"], cwd=content_root)
        run(["git", "add", "."], cwd=content_root)
        commit = run(["git", "commit", "-m", "Initialize bSmart content"], cwd=content_root, check=False)
        if commit.returncode != 0 and "nothing to commit" not in (commit.stdout + commit.stderr):
            return f"initialized; initial commit skipped ({commit.stderr.strip() or commit.stdout.strip()})"
        return "initialized local git"
    return "already present"


def main() -> int:
    parser = argparse.ArgumentParser(description="Bootstrap bSmart into a Hermes workspace mount.")
    parser.add_argument("--workspace", required=True, help="Host path backing the container's /workspace mount")
    parser.add_argument("--agent-name", required=True, help="Display name for this AI instance")
    parser.add_argument("--role", default="Constrained Hermes assistant")
    parser.add_argument("--operator", default="operator")
    parser.add_argument("--repo-url", default=DEFAULT_REPO_URL)
    parser.add_argument("--projects-root", default="/projects", help="Container path for canonical projects root")
    parser.add_argument("--sandboxes-root", default="/sandboxes", help="Container path for canonical sandboxes root")
    parser.add_argument("--host-project-root", default="", help="Optional host path backing /projects; recorded in State/container-storage.yaml")
    parser.add_argument("--host-sandbox-root", default="", help="Optional host path backing /sandboxes; recorded in State/container-storage.yaml")
    parser.add_argument("--uid", type=int, default=10000, help="Hermes runtime UID for ownership")
    parser.add_argument("--gid", type=int, default=10000, help="Hermes runtime GID for ownership")
    parser.add_argument("--content-git", choices=["none", "local"], default="none", help="Optional local Git for /workspace/bSmart content; no remote is configured")
    args = parser.parse_args()

    workspace = Path(args.workspace).expanduser().resolve()
    install_dir(workspace, args.uid, args.gid)

    system_action = ensure_system_repo(workspace, args.repo_url)

    content_root = workspace / "bSmart"
    for rel in ["Docs", "Library", "Projects", "Sandboxes", "Workdocs", "State"]:
        install_dir(content_root / rel, args.uid, args.gid)
    install_dir(workspace / "bSmart-Extensions", args.uid, args.gid)

    files_created: list[str] = []
    if write_if_missing(workspace / "HERMES.md", HERMES_HOOK):
        files_created.append("HERMES.md")

    agent_md = f"""# bSmart agent profile

```yaml
agent:
  name: {args.agent_name}
  role: {args.role}
  operator: {args.operator}
  framework: Hermes

bsmart:
  system_root: /workspace/bSmart-System
  content_root: /workspace/bSmart
  extensions_root: /workspace/bSmart-Extensions

access_model:
  writable_paths:
    - /workspace
    - {args.projects_root}
    - {args.sandboxes_root}
  secrets:
    path: /run/secrets
    mode: read_only
  unavailable_by_default:
    - Docker socket
    - broad host filesystem access
    - host runtime/backups/blueprint mounts

operating_policy:
  posture: concise, practical, confidentiality-aware
  host_changes: require explicit operator approval
  bsmart_system_updates: public HTTPS fast-forward only

local_paths:
  content_root: /workspace/bSmart
  project_root_selection:
    - BSMART_PROJECT_ROOT
    - {args.projects_root}
    - ./projects
    - /workspace/bSmart/Projects
  sandbox_root_selection:
    - BSMART_SANDBOX_ROOT
    - {args.sandboxes_root}
    - ./sandboxes
    - ./bSmart/Sandboxes
```
"""
    if write_if_missing(content_root / "bSmart_Agent.md", agent_md):
        files_created.append("bSmart/bSmart_Agent.md")

    if write_if_missing(content_root / "bSmart_State.md", "# bSmart state\n\n- Mode: `Free`\n- Active project (short name): `none`\n"):
        files_created.append("bSmart/bSmart_State.md")

    todo = """# bSmart TODO

## Next tasks
- ⬜ Verify Telegram startup after `/new` then `Hi`.
- ⬜ Review and complete `/workspace/bSmart/bSmart_Agent.md` for this instance.
- ⬜ Create/select first project when needed.
"""
    if write_if_missing(content_root / "bSmart_TODO.md", todo):
        files_created.append("bSmart/bSmart_TODO.md")

    if write_if_missing(content_root / "bSmart_Log.md", f"# bSmart log\n\n- Initial bSmart setup for {args.agent_name}.\n"):
        files_created.append("bSmart/bSmart_Log.md")

    storage = f"""# bSmart container storage

```yaml
projects:
  container_root: {args.projects_root}
  host_root: {args.host_project_root or 'unknown'}
  status: verify_after_deploy
sandboxes:
  container_root: {args.sandboxes_root}
  host_root: {args.host_sandbox_root or 'unknown'}
  status: verify_after_deploy
```
"""
    if write_if_missing(content_root / "State" / "container-storage.yaml", storage):
        files_created.append("bSmart/State/container-storage.yaml")

    chown_tree(workspace / "HERMES.md", args.uid, args.gid) if (workspace / "HERMES.md").exists() else None
    for p in [workspace / "bSmart-System", content_root, workspace / "bSmart-Extensions"]:
        chown_tree(p, args.uid, args.gid)

    content_git = maybe_init_content_git(content_root, args.content_git, args.agent_name)
    chown_tree(content_root, args.uid, args.gid)

    print("bSmart workspace bootstrap complete")
    print(f"  workspace: {workspace}")
    print(f"  bSmart-System: {system_action} from {args.repo_url}")
    print(f"  local content files created: {', '.join(files_created) if files_created else 'none (already present)'}")
    print(f"  bSmart content Git: {content_git}")
    print("\nRequired Compose/Dokploy defaults for this instance:")
    print("  working_dir: /workspace")
    print("  environment:")
    print("    TERMINAL_CWD: /workspace")
    print("    HERMES_WRITE_SAFE_ROOT: /workspace")
    print("  volumes:")
    print("    - <host-workspace>:/workspace")
    print("    - <host-hermes-data>:/opt/data")
    print("    - <host-secrets>:/run/secrets:ro")
    print("\nVerification after restart/redeploy:")
    print("  1. Send /new to the bot")
    print("  2. Send Hi")
    print("  3. Confirm it reports bSmart startup and no GitHub SSH-key warning")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
