#!/usr/bin/env python3
"""bSmart project/sandbox storage check and local spec helper.

This helper is intentionally local and non-deploying. It can:
- report whether the instance storage spec exists;
- report whether /projects and /sandboxes are mounted/usable;
- create the local spec only when explicitly asked with --configure-*.

It never edits Docker Compose, Dokploy, host mounts, or runtime services.
"""

from __future__ import annotations

import argparse
import datetime as dt
import os
import subprocess
import sys
from pathlib import Path

DEFAULT_CONTENT_ROOT = Path("/workspace/bSmart")
SCRIPT_DIR = Path(__file__).resolve().parent
SYSTEM_ROOT = SCRIPT_DIR.parent
WORKSPACE_ROOT = SYSTEM_ROOT.parent
CONTENT_ROOT = DEFAULT_CONTENT_ROOT if DEFAULT_CONTENT_ROOT.exists() else WORKSPACE_ROOT / "bSmart"
DEFAULT_SPEC = CONTENT_ROOT / "State" / "container-storage.yaml"


def workspace_root() -> Path:
    env_root = os.environ.get("BSMART_WORKSPACE_ROOT")
    if env_root:
        return Path(env_root).expanduser()
    cwd = Path.cwd()
    if (cwd / "bSmart-System").is_dir() or (cwd / "AGENTS.md").exists() or (cwd / "HERMES.md").exists():
        return cwd
    return WORKSPACE_ROOT


def access(path: Path) -> dict[str, object]:
    return {
        "exists": path.exists(),
        "is_dir": path.is_dir(),
        "readable": os.access(path, os.R_OK),
        "writable": os.access(path, os.W_OK),
        "executable": os.access(path, os.X_OK),
    }


def status_word(info: dict[str, object]) -> str:
    if not info["exists"]:
        return "missing"
    if info["is_dir"] and info["readable"] and info["writable"] and info["executable"]:
        return "usable"
    return "present_but_not_usable"


def usable(path: Path) -> bool:
    return status_word(access(path)) == "usable"


def project_root_candidates() -> list[tuple[str, Path]]:
    candidates: list[tuple[str, Path]] = []
    override = os.environ.get("BSMART_PROJECT_ROOT")
    if override:
        candidates.append(("BSMART_PROJECT_ROOT", Path(override).expanduser()))
    candidates.extend(
        [
            ("/projects", Path("/projects")),
            ("./projects", workspace_root() / "projects"),
            ("fallback", Path("/workspace/bSmart/Projects")),
            ("./bSmart/Projects", workspace_root() / "bSmart" / "Projects"),
        ]
    )
    return candidates


def select_project_root() -> tuple[str, Path] | None:
    for label, path in project_root_candidates():
        if usable(path):
            return label, path
    return None


def sandbox_root_candidates() -> list[tuple[str, Path]]:
    candidates: list[tuple[str, Path]] = []
    override = os.environ.get("BSMART_SANDBOX_ROOT")
    if override:
        candidates.append(("BSMART_SANDBOX_ROOT", Path(override).expanduser()))
    candidates.extend(
        [
            ("/sandboxes", Path("/sandboxes")),
            ("./sandboxes", workspace_root() / "sandboxes"),
            ("./bSmart/Sandboxes", workspace_root() / "bSmart" / "Sandboxes"),
        ]
    )
    return candidates


def select_sandbox_root() -> tuple[str, Path] | None:
    for label, path in sandbox_root_candidates():
        if usable(path):
            return label, path
    return None


def run(cmd: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)


def infer_workspace_host_path() -> str | None:
    proc = run(["findmnt", "-T", "/workspace", "-n", "-o", "SOURCE"])
    if proc.returncode != 0:
        return None
    source = proc.stdout.strip()
    if not source:
        return None
    # Overlay/bind output can look like: /dev/sda1[/opt/docker-workspace/x/workspace]
    if "[" in source and source.endswith("]"):
        return source.rsplit("[", 1)[1][:-1]
    if source.startswith("/"):
        return source
    return None


def infer_sandbox_host_path(project_host_folder: str | None = None) -> str | None:
    """Infer the host sandboxes path.

    Prefer project-host folder patterns such as `/mnt/share/JenZa` so a dry run
    in SschwAdmin can still produce the right target for a different instance.
    Fall back to a sibling of the host path backing this container's /workspace.
    """
    if project_host_folder:
        project = Path(project_host_folder)
        if len(project.parts) >= 3 and project.parts[1] == "mnt" and project.parts[2] == "share":
            slug = project.name.lower()
            special = {"jenza": "ai/jenza", "sschwaadmin": "hermes-admin", "sschwadmin": "hermes-admin"}
            scope = special.get(slug, f"hermes-{slug}")
            return f"/opt/docker-workspace/{scope}/sandboxes"

    workspace_host = infer_workspace_host_path()
    if not workspace_host:
        return None
    workspace = Path(workspace_host)
    if workspace.name == "workspace":
        return str(workspace.parent / "sandboxes")
    return None


def write_spec(spec_path: Path, content: str) -> None:
    spec_path.parent.mkdir(parents=True, exist_ok=True)
    if spec_path.exists():
        raise SystemExit(f"Refusing to overwrite existing spec: {spec_path}")
    spec_path.write_text(content, encoding="utf-8")


def quote_shell(value: str) -> str:
    return "'" + value.replace("'", "'\\''") + "'"


def print_predeploy_commands(host_project_folder: str, host_sandbox_folder: str | None) -> None:
    print("Required host prep before adding Compose/Dokploy volume lines:")
    print("  # Run these first, then verify they succeed. Do not add the volume lines before this step.")
    print(f"  sudo mkdir -p {quote_shell(host_project_folder)}")
    if host_sandbox_folder:
        q = quote_shell(host_sandbox_folder)
        print(f"  sudo install -d -o 10000 -g 10000 -m 0775 {q}")
    else:
        print("  sudo install -d -o 10000 -g 10000 -m 0775 <host-sandbox-folder>")
    print("")


def spec_text(mode: str, project_root: str, host_project_folder: str, sandbox_root: str, host_sandbox_folder: str | None, backing: str) -> str:
    generated = dt.datetime.now(dt.UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z")
    sandbox_host = host_sandbox_folder or "TODO: host path backing /sandboxes"
    return f"""# bSmart container storage spec
# Local instance state. Do not put this file inside the project volume.
generated_at: {generated}

container_storage:
  project_root:
    path_in_container: {project_root}
    required: true
    backing: {backing}
    desired_host_path: {host_project_folder}
    mode: rw
  sandbox_root:
    path_in_container: {sandbox_root}
    required: true
    backing: vps-local
    desired_host_path: {sandbox_host}
    mode: rw

project_storage:
  mode: {mode}
  project_root: {project_root}
  host_project_folder: {host_project_folder}

sandbox_storage:
  mode: vps_local_preferred
  sandbox_root: {sandbox_root}
  host_sandbox_folder: {sandbox_host}
"""


def print_status(spec_path: Path) -> int:
    project_candidates = project_root_candidates()
    sandbox_candidates = sandbox_root_candidates()

    spec_exists = spec_path.exists()
    selected_project = select_project_root()
    selected_sandbox = select_sandbox_root()

    print("bSmart project storage check:")
    print(f"  spec: {'present' if spec_exists else 'missing'} ({spec_path})")
    for label, path in project_candidates:
        display = str(path) if label != str(path) else label
        print(f"  project candidate {label}: {status_word(access(path))} ({display})")
    for label, path in sandbox_candidates:
        display = str(path) if label != str(path) else label
        print(f"  sandbox candidate {label}: {status_word(access(path))} ({display})")
    if selected_project:
        print(f"  selected_project_root: {selected_project[1]} ({selected_project[0]})")
    if selected_sandbox:
        print(f"  selected_sandbox_root: {selected_sandbox[1]} ({selected_sandbox[0]})")

    if spec_exists:
        if selected_project and selected_sandbox:
            print("  result: configured; selected project and sandbox roots are usable")
            return 0
        if not selected_project:
            print("  result: spec exists, but no configured project root is usable; set BSMART_PROJECT_ROOT, add /projects, or launch from a workspace with ./projects")
        if not selected_sandbox:
            print("  result: spec exists, but no sandbox root is usable; set BSMART_SANDBOX_ROOT, add /sandboxes, or launch from a workspace with ./sandboxes")
        return 1

    print("  result: setup_required")
    print("")
    print("bSmart - Project configuration")
    print("Choose location for project folders:")
    print("1) Mounted volume (e.g. external to Docker image and possibly a mounted SMB drive)")
    print("2) Internal bSmart (standard bSmart project folder inside the container workspace)")
    print("Some things will be stored in an internal project sandbox.")
    print("")
    print("To record the choice with this helper:")
    print("  Mounted volume:  bsmart-project-storage-check --configure-mounted --host-project-folder <host-path>")
    print("  Internal bSmart:  bsmart-project-storage-check --configure-internal")
    return 2


def main() -> int:
    parser = argparse.ArgumentParser(description="Check or create bSmart container storage spec.")
    parser.add_argument("--spec", default=str(DEFAULT_SPEC), help="storage spec path")
    parser.add_argument("--configure-mounted", action="store_true", help="create spec for a mounted /projects volume")
    parser.add_argument("--configure-internal", action="store_true", help="create spec using /workspace/bSmart/Projects as the host-backed source")
    parser.add_argument("--host-project-folder", help="host path to mount at /projects")
    parser.add_argument("--host-sandbox-folder", help="host path to mount at /sandboxes; defaults to sibling 'sandboxes' next to the host /workspace path when inferable")
    args = parser.parse_args()

    if not args.host_sandbox_folder:
        args.host_sandbox_folder = infer_sandbox_host_path(args.host_project_folder)

    spec_path = Path(args.spec)
    if args.configure_mounted and args.configure_internal:
        raise SystemExit("Choose only one of --configure-mounted or --configure-internal")

    if args.configure_mounted:
        if not args.host_project_folder:
            raise SystemExit("--configure-mounted requires --host-project-folder")
        write_spec(
            spec_path,
            spec_text(
                mode="mounted",
                project_root="/projects",
                host_project_folder=args.host_project_folder,
                sandbox_root="/sandboxes",
                host_sandbox_folder=args.host_sandbox_folder,
                backing="custom",
            ),
        )
        print(f"bSmart project storage: wrote {spec_path}")
        print_predeploy_commands(args.host_project_folder, args.host_sandbox_folder)
        print("After the required host prep succeeds, add these Compose/Dokploy volume lines:")
        print(f"Project volume line: - {args.host_project_folder}:/projects:rw")
        if args.host_sandbox_folder:
            print(f"Sandbox volume line: - {args.host_sandbox_folder}:/sandboxes:rw")
        else:
            print("Sandbox volume line: - <host-sandbox-folder>:/sandboxes:rw")
        return 0

    if args.configure_internal:
        workspace_host = infer_workspace_host_path()
        if workspace_host:
            host_project_folder = f"{workspace_host.rstrip('/')}/bSmart/Projects"
        else:
            host_project_folder = "TODO: host path backing /workspace/bSmart/Projects"
        write_spec(
            spec_path,
            spec_text(
                mode="internal_bsmart",
                project_root="/projects",
                host_project_folder=host_project_folder,
                sandbox_root="/sandboxes",
                host_sandbox_folder=args.host_sandbox_folder,
                backing="vps-local",
            ),
        )
        print(f"bSmart project storage: wrote {spec_path}")
        print_predeploy_commands(host_project_folder, args.host_sandbox_folder)
        print("After the required host prep succeeds, add these Compose/Dokploy volume lines:")
        print(f"Project volume line: - {host_project_folder}:/projects:rw")
        if args.host_sandbox_folder:
            print(f"Sandbox volume line: - {args.host_sandbox_folder}:/sandboxes:rw")
        else:
            print("Sandbox volume line: - <host-sandbox-folder>:/sandboxes:rw")
        return 0

    return print_status(spec_path)


if __name__ == "__main__":
    raise SystemExit(main())
